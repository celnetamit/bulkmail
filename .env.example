# Auth
AUTH_SECRET=replace-with-strong-random-secret
APP_URL=https://bemail.panoptical.org
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional comma-separated override; defaults already include amit.rai@celnet.in and puneet.mehrotra@celnet.in
ADMIN_EMAIL_ALLOWLIST=amit.rai@celnet.in,puneet.mehrotra@celnet.in

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/bulkmail?schema=public

# Email provider selection: mock | resend | aws-ses
MAIL_PROVIDER=mock

# Required only when MAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com

# Required only when MAIL_PROVIDER=aws-ses
AWS_REGION=ap-south-1
AWS_SES_FROM_EMAIL=no-reply@example.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional if you use temporary credentials or an IAM role
AWS_SESSION_TOKEN=
# AWS credentials are resolved by the default AWS SDK provider chain,
# so these env vars are enough for local development.

# Webhook shared secret (optional but recommended)
WEBHOOK_SHARED_SECRET=
