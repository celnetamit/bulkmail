// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("USER") // ADMIN, MANAGER, USER
  isActive  Boolean  @default(true)
  dailyEmailLimit Int @default(100000)
  imageUploadLimitKb Int?
  senderFromEmail String?
  senderReplyToEmail String?
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lists     List[]
  templates Template[]
  campaigns Campaign[]
  sendJobs  CampaignSendJob[]
  mailSettings MailSettings?
  managedTeams Team[] @relation("ManagedTeams")
  teamMembership TeamMember?
  resourceMetrics ResourceMetric[]
  agentConversations AgentConversation[]
  systemEvents SystemEvent[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  description String?
  dailyCreditLimit Int @default(100000)
  managerId String
  manager   User     @relation("ManagedTeams", fields: [managerId], references: [id])
  members   TeamMember[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String   @unique
  allocatedDailyLimit Int @default(100000)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailSettings {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  provider                  String   @default("mock")
  awsRegion                 String?
  awsFromEmail              String?
  awsAccessKeyIdEncrypted   String?
  awsSecretAccessKeyEncrypted String?
  awsSessionTokenEncrypted   String?
  resendApiKeyEncrypted     String?
  resendFromEmail           String?
  webhookSharedSecretEncrypted String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                String   @id @default("global")
  imageUploadLimitKb Int      @default(50)
  sendingDomain     String?
  spfVerified       Boolean  @default(false)
  dkimVerified      Boolean  @default(false)
  dmarcVerified     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Template {
  id        String     @id @default(cuid())
  name      String
  subject   String
  bodyHtml  String
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model List {
  id          String    @id @default(cuid())
  name        String
  description String?
  userId      String
  isDefaultTestList Boolean @default(false)
  isArchived  Boolean   @default(false)
  user        User      @relation(fields: [userId], references: [id])
  contacts    Contact[]
  campaigns   Campaign[]
  campaignLists CampaignList[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contact {
  id           String   @id @default(cuid())
  email        String
  firstName    String?
  lastName     String?
  status       String   @default("SUBSCRIBED") // SUBSCRIBED, UNSUBSCRIBED, BOUNCED
  listId       String
  list         List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  events       Event[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([email, listId])
}

model Campaign {
  id        String   @id @default(cuid())
  name      String
  subject   String
  bodyHtml  String
  status    String   @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT
  provider  String?
  isArchived Boolean  @default(false)
  totalRecipients Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  skippedCount    Int      @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  durationSeconds Int?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listId    String
  list      List     @relation(fields: [listId], references: [id])
  campaignLists CampaignList[]
  templateId String?
  template  Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  events    Event[]
  resourceMetrics ResourceMetric[]
  sendJobs  CampaignSendJob[]
  systemEvents SystemEvent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id         String   @id @default(cuid())
  type       String   // SENT, DELIVERED, OPENED, CLICKED, BOUNCED, UNSUBSCRIBED
  provider   String?
  providerEventId String? @unique
  providerMessageId String?
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model CampaignList {
  id         String   @id @default(cuid())
  campaignId String
  listId     String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  list       List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([campaignId, listId])
  @@index([campaignId])
  @@index([listId])
}

model ResourceMetric {
  id                   String   @id @default(cuid())
  scopeType            String
  eventType            String
  userId               String?
  campaignId           String?
  cpuUserMs            Float
  cpuSystemMs          Float
  memoryRssMb          Float
  memoryHeapUsedMb     Float
  memoryHeapTotalMb    Float
  eventLoopUtilization  Float
  activeHandles        Int
  activeRequests       Int
  loadAverage1m        Float
  loadAverage5m        Float
  loadAverage15m       Float
  sentCount            Int      @default(0)
  failedCount          Int      @default(0)
  skippedCount         Int      @default(0)
  recipientCount       Int      @default(0)
  durationMs           Int?
  note                 String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign             Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt            DateTime  @default(now())

  @@index([createdAt])
  @@index([scopeType, createdAt])
  @@index([userId, createdAt])
  @@index([campaignId, createdAt])
}

model SystemEvent {
  id          String   @id @default(cuid())
  level       String
  source      String
  message     String
  userId      String?
  campaignId  String?
  details     String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([level, createdAt])
  @@index([source, createdAt])
}

model CampaignSendJob {
  id              String   @id @default(cuid())
  campaignId      String
  userId          String
  status          String   @default("QUEUED")
  attempts        Int      @default(0)
  provider        String?
  totalRecipients Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  skippedCount    Int      @default(0)
  quotaSkippedCount Int    @default(0)
  remainingToday  Int      @default(0)
  requestedAt     DateTime @default(now())
  startedAt       DateTime?
  nextRunAt       DateTime?
  finishedAt      DateTime?
  lastError       String?
  skipReason      String?
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, requestedAt])
  @@index([campaignId])
}

model AiAgentProfile {
  id              String   @id @default(cuid())
  agentKey        String   @unique
  label           String
  description     String?
  provider        String   @default("openrouter")
  model           String
  baseUrl         String?
  apiKeyEncrypted String?
  systemPrompt    String
  temperature     Float    @default(0.4)
  maxOutputTokens Int      @default(1200)
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentConversation {
  id           String        @id @default(cuid())
  agentKey     String
  title        String?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     AgentMessage[]
  lastMessageAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId, agentKey, updatedAt])
}

model AgentMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           String
  content        String
  metadataJson   String?
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
}
